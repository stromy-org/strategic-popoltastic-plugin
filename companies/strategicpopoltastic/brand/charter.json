  "document": {
    "margins": { "top": "1in", "bottom": "1in", "left": "1in", "right": "1in" },
    "header": { "content": "Strategic Popoltastic", "logo": true },
    "footer": { "content": "Confidential", "pageNumbers": true },
    "headingColor": "primary",
    "tableHeaderColor": "secondary"
  },
  "presentation": {
    "slideMargin": "40pt",
    "titleMargin": "30pt",
    "contentMargin": "20pt",
    "aspectRatio": "16:9"
  },
  "video": {
    "resolution": "1920x1080",
    "fps": 30
  },
  "formatting": {
    "headingThreshold": 24,
    "accentCycleColors": ["primary", "accent", "success"],
    "autoContrastText": true
  },
  "plotly": {
    "categoricalPalette": ["#1B3A5C", "#7FB3D3", "#4A8F7A", "#B8935A", "#4A72A0", "#6E7681"],
    "defaultHeight": 500,
    "titleFontSize": 18,
    "axisFontSize": 12,
    "legendFontSize": 11,
    "margins": { "top": 80, "bottom": 70, "left": 60, "right": 50 },
    "baseTemplate": "plotly_white",
    "gridColor": "#E6EDF3",
    "secondaryTextColor": "#8B949E",
    "bar": {
      "markerColor": "#1B3A5C",
      "markerLineColor": "#0A1628",
      "markerLineWidth": 1
    },
    "line": {
      "color": "#1B3A5C",
      "width": 2.5,
      "markerColor": "#7FB3D3",
      "markerSize": 7
    },
    "scatter": {
      "markerColor": "#1B3A5C",
      "markerSize": 8,
      "markerLineWidth": 0
    },
    "pie": {
      "hole": 0.4,
      "textfontSize": 13,
      "markerLineColor": "#F8F9FA",
      "markerLineWidth": 2
    },
    "sentiment": {
      "positiveColor": "#4A8F7A",
      "neutralColor": "#8B949E",
      "negativeColor": "#A65454"
    }
  },
  "templates": {
    "pptx": {
      "default": "templates/pptx/default.pptx"
    },
    "docx": {
      "default": "templates/docx/default.docx",
      "letterhead": "templates/docx/letterhead.docx"
    },
    "html": {
      "business-cards": "templates/html/business-cards.html",
      "email-signature": "templates/html/email-signature.html"
    }
  }
